PORT=5000
NODE_ENV=development
# Use either DB_CONNECTION_STRING or the individual DB_* settings below.
# DB_CONNECTION_STRING=Driver={SQL Server Native Client 11.0};Server=(localdb)\\MSSQLLocalDB;Database=EgySystem;Trusted_Connection=Yes;Encrypt=no;TrustServerCertificate=Yes;ApplicationIntent=ReadWrite;MultiSubnetFailover=No;Connection Timeout=30;
# DB_CONNECTION_STRING=Server=localhost,1433;Database=EgySystem;User Id=myuser;Password=mypassword;
DB_CONNECTION_STRING=
DB_DRIVER=msnodesqlv8
DB_SERVER=localhost
DB_PORT=
DB_NAME=EgySystem
# Use SQL Server authentication if your instance is not Windows-integrated.
DB_USER=
DB_PASSWORD=
# Set to true for Windows Trusted Connection using msnodesqlv8 if installed.
DB_TRUSTED=false
JWT_SECRET=your_very_long_random_secret_here_min_32_chars
JWT_EXPIRE=30d
CORS_ORIGIN=http://localhost:5173

